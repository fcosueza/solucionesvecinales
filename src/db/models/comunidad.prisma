model Comunidad {
  id        Int     @id @default(autoincrement())
  nombre    String
  imagen    String?
  calle     String
  numero    Int
  ciudad    String
  provincia String
  pais      String

  mensajes             Mensaje[]
  zonas                Zona[]
  incidentes           Incidencia[]
  solicitudes          Solicitud[]
  inscripciones        Inscripcion[]
  registrosFinancieros Registro[]

  adminID String
  admin   Usuario @relation("admin", fields: [adminID], references: [id])
}
