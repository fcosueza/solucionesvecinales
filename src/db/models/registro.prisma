enum TipoRegistro {
    ingreso
    gasto
}

model Registro {
    id          Int          @id @default(autoincrement())
    comunidad   Int
    descripcion String
    importe     Decimal      @db.Decimal(12, 2)
    tipo        TipoRegistro
    creadoEn    DateTime     @default(now())

    comunidadID Comunidad @relation(fields: [comunidad], references: [id], onDelete: Cascade)

    @@index([comunidad, tipo, creadoEn])
}
