enum Rol {
  inquilino
  admin
  adminWeb
}

model Usuario {
  id       String  @id @default(uuid())
  email    String  @unique
  rol      Rol     @default(inquilino)
  nombre   String
  apellido String
  imagen   String?

  credenciales Credenciales?
  incidencias  Incidencia[]
  reservas     Reserva[]
  solicitudes  Solicitud[]
  inscripciones Inscripcion[]

  adminComm Comunidad[] @relation("admin")
}
