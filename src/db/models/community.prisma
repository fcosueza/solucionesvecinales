model Community {
  id       Int     @id @default(autoincrement())
  name     String
  image    String?
  street   String
  number   Int
  city     String
  province String
  country  String

  messages         Message[]
  zones            Zone[]
  incidents        Incident[]
  requests         Request[]
  memberships      Membership[]
  financialRecords FinancialRecord[]

  adminId String
  admin   User   @relation("admin", fields: [adminId], references: [id])
}
